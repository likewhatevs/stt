#!/bin/sh
#
# pre-push hook: require `cargo build --tests` to succeed for every
# commit being pushed. Catches SHAs that compile the library but break
# the test build (e.g. a field rename that missed a cfg(test) call
# site) — without this, the main CI gate is the first signal, and the
# broken SHA has already entered shared history.
#
# Runs once against the current worktree, which covers the tip SHA.
# A full per-commit sweep would require checking out each range-to-push
# SHA and rebuilding, which multiplies wall time by the push depth;
# the tip-only check is the 95% catch at 1/N the cost.
#
# To enable locally:
#   git config core.hooksPath .githooks
#
# Skip with --no-verify if you have a deliberate WIP-push need; prefer
# fixing the breakage instead.

# Dirty-tree check: refuse to push when the worktree has uncommitted
# changes or staged-but-uncommitted changes. A dirty tree during push
# means the test-build gate below is running against a mix of the
# pushed SHA plus local edits, so a passing build doesn't actually
# prove the pushed SHA is green. Either commit, stash, or pass
# --no-verify after confirming the dirty state is benign.
if ! git diff --quiet; then
    echo "pre-push: working tree has uncommitted changes. Commit or stash"
    echo "          before pushing; the test-build gate runs against the"
    echo "          worktree (not the pushed SHA in isolation), so a"
    echo "          dirty tree would miscertify the push."
    exit 1
fi
if ! git diff --cached --quiet; then
    echo "pre-push: index has staged-but-uncommitted changes. Commit or"
    echo "          stash before pushing — same rationale as above."
    exit 1
fi

# Untracked-file check: warn (do not block) when the worktree contains
# files not known to git. Untracked files are not compiled by
# `cargo build --tests` and are not part of the pushed SHA, so they
# cannot miscertify the push the way a dirty tracked file does — but
# they are often forgotten new sources, test fixtures, or working
# artifacts that the author meant to `git add` before pushing. A
# warning surfaces the oversight without blocking pushes when the
# untracked files are genuinely local-only (e.g. profraw, scratch
# notes).
untracked=$(git ls-files --others --exclude-standard)
if [ -n "$untracked" ]; then
    echo "pre-push: WARNING — untracked files present in worktree:"
    echo "$untracked" | sed 's/^/          /'
    echo "          These are not part of the pushed SHA. If any are"
    echo "          new sources you meant to include, abort, add them,"
    echo "          and re-push."
fi

if ! command -v cargo >/dev/null 2>&1; then
    echo "pre-push: cargo not found, skipping test-build gate"
    exit 0
fi

echo "pre-push: running cargo build --tests..."
if ! cargo build --tests --quiet; then
    echo
    echo "pre-push: cargo build --tests FAILED. Fix the test build"
    echo "          before pushing, or pass --no-verify to override."
    exit 1
fi

exit 0
