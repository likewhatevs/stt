#!/bin/sh

if command -v cargo >/dev/null 2>&1; then
    echo "Running cargo fmt..."
    cargo fmt --all

    echo "Running cargo clippy..."
    cargo clippy --workspace --all-targets --features integration -- -D warnings
    if [ $? -ne 0 ]; then
        echo "clippy failed, aborting commit"
        exit 1
    fi
else
    echo "Warning: cargo not found, skipping fmt and clippy"
fi

# Re-add only files that were already staged, in case cargo fmt
# reformatted them. Do NOT stage untracked or deliberately-unstaged
# files — that causes scope creep in commits.
git diff --cached --name-only --diff-filter=ACM | xargs -r git add

exit 0
